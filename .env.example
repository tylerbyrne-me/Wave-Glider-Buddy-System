# Copy to `.env` and adjust. Pydantic Settings reads `.env` from the process working directory (project root).

# --- Public URL (Chrome / Safari / KML) ---
# Must match exactly what users type in the browser: scheme, host, and non-default port.
# Wrong values break cookie expectations and absolute links (e.g. KML network links).
# Examples:
#   APP_BASE_URL=http://localhost:8000
#   APP_BASE_URL=https://gliderbuddy.example.com
APP_BASE_URL=http://localhost:8000

# --- HTTPS and cookies ---
# When users reach the app with https://, set true so auth cookies use Secure and session middleware uses https_only.
# Cookie flags are NOT inferred from X-Forwarded-Proto; you must set this to match the public URL.
# If the site is http-only, keep false (Secure cookies are not sent over HTTP).
APP_USE_HTTPS=false

# --- TLS (production HTTPS) ---
# Chrome and Safari require a trusted certificate chain (hostname match, not expired).
# Use a public CA (e.g. Let's Encrypt) or install your internal root/intermediate CA on client devices.
# Self-signed certs that are only "accepted" in Firefox will still fail in Chrome/Safari until the CA is trusted.

# --- JWT (required in production) ---
# JWT_SECRET_KEY=
